        "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: $('Store Operation Name').item.json.prompt }] }], generationConfig: { responseModalities: [\"IMAGE\"] } }) }}",
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth"
      },
