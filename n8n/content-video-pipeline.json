        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-haiku-4-5-20251001\", max_tokens: 1024, messages: [{ role: \"user\", content: `You are generating short cinematic AI video prompts for a smoking/vaping cessation app's content feed. Theme: \"${$json.theme}\". Generate exactly ${$('Set Config').first().json.VIDEOS_PER_THEME} distinct 6-8 second video prompts for this theme. Prompts must be vivid and visual, abstract/nature/human-subject only, no on-screen text, no close-up faces, no smoking or vaping imagery \u2014 each prompt also doubles as a still-frame description for a matching thumbnail image. Respond with ONLY a JSON array of prompt strings \u2014 no markdown, no commentary.` }] }) }}",
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth"
      },
      "credentials": {
        "httpCustomAuth": {
          "id": "K1WqxgX2EaEGui4m",
          "name": "Anthropic API (BattleBuddy)"
