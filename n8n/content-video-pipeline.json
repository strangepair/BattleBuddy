    {
      "id": "a1b2c3d4-0007-4000-8000-000000000007",
      "name": "Parse Claude Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        80
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const theme = $('Split By Theme').first().json.theme;\nconst raw = $input.first().json.content[0].text;\nconst match = raw.match(/\\[[\\s\\S]*\\]/);\nconst prompts = JSON.parse(match ? match[0] : raw);\nreturn prompts.map((prompt) => ({ json: { theme, prompt } }));"
      }
    },
