    {
      "id": "a1b2c3d4-0026-4000-8000-000000000026",
      "name": "Decode Thumbnail",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        80
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const parts = ($json.candidates && $json.candidates[0] && $json.candidates[0].content && $json.candidates[0].content.parts) || [];\nconst imagePart = parts.find((p) => p.inlineData && p.inlineData.data);\nif (!imagePart) {\n  throw new Error('No image data in Gemini response');\n}\nconst base64 = imagePart.inlineData.data;\nconst buffer = Buffer.from(base64, 'base64');\nconst binary = await $helpers.prepareBinaryData(buffer, 'thumbnail.png', imagePart.inlineData.mimeType || 'image/png');\nreturn {\n  json: {\n    operationName: $('Store Operation Name').item.json.operationName,\n    theme: $('Store Operation Name').item.json.theme,\n    prompt: $('Store Operation Name').item.json.prompt,\n  },\n  binary: { data: binary },\n};"
      }
