    {
      "id": "a1b2c3d4-0022-4000-8000-000000000022",
      "name": "Read Poll Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2720,
        80
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const op = $json;\nlet pollAttempts = 0;\ntry {\n  pollAttempts = $('Increment Attempt').item.json.pollAttempts;\n} catch (e) {\n  pollAttempts = 0;\n}\nlet status = 'RUNNING';\nlet output = null;\nlet failureReason = null;\nif (op.done) {\n  if (op.error) {\n    status = 'FAILED';\n    failureReason = op.error.message || JSON.stringify(op.error);\n  } else {\n    const samples = (op.response && op.response.generateVideoResponse && op.response.generateVideoResponse.generatedSamples) || [];\n    const uri = samples[0] && samples[0].video && samples[0].video.uri;\n    if (uri) {\n      status = 'SUCCEEDED';\n      output = [uri];\n    } else {\n      status = 'FAILED';\n      failureReason = 'Operation done but no video URI in response';\n    }\n  }\n}\nreturn {\n  json: {\n    status,\n    output,\n    failureReason,\n    operationName: $('Store Operation Name').item.json.operationName,\n    theme: $('Store Operation Name').item.json.theme,\n    prompt: $('Store Operation Name').item.json.prompt,\n    pollAttempts,\n  },\n};"
      }
    },
